"\r\n            SELECT a.date,\r\n                   AES_DECRYPT(a.chalan_no,'Th@#981420314') AS invoiceno,\r\n                   AES_DECRYPT(b.supplier_name,'Th@#981420314') AS supplier_name,\r\n                   CAST(AES_DECRYPT(a.grandTotal,'Th@#981420314') AS DECIMAL(18,2)) AS total,\r\n                   'Purchase' AS type,\r\n                    CASE\r\n            WHEN  a.incidenttype = '1' THEN 'International Purchase'\r\n            WHEN  a.incidenttype = '2' THEN 'Local Purchase'\r\n            ELSE 'Unknown'\r\n        END AS incidenttype\r\n            FROM purchase a\r\n            JOIN supplier_information b ON b.supplier_id = a.supplier_id\r\n            WHERE a.date >= '2026-04-01' AND a.date <= '2026-06-13'\r\n               AND AES_DECRYPT(a.type2,'Th@#981420314') = 'A' AND a.incidenttype = '3'\r\n\r\n            UNION ALL\r\n\r\n            SELECT r.date,\r\n                   AES_DECRYPT(p.chalan_no,'Th@#981420314') AS invoiceno,\r\n                   AES_DECRYPT(b.supplier_name,'Th@#981420314') AS supplier_name,\r\n                   -CAST(AES_DECRYPT(r.grandTotal,'Th@#981420314') AS DECIMAL(18,2)) AS total,\r\n                   'Purchase Return' AS type,\r\n                    'Purchase Return' AS incidenttype\r\n            FROM purchase_return r\r\n            JOIN purchase p ON p.id = r.purchase_id\r\n            JOIN supplier_information b ON b.supplier_id = r.supplier_id\r\n            WHERE r.date >= '2026-04-01' AND r.date <= '2026-06-13'\r\n               AND AES_DECRYPT(r.type2,'Th@#981420314') = 'A' AND r.incidenttype = 3\r\n            ORDER BY date DESC\r\n        "
